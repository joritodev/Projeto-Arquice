# Base URL do backend (sem barra no fim).
# Desenvolvimento local:
# VITE_ADMIN_API_BASE_URL=http://localhost:3000
#
# Produção (Vercel → Render):
# VITE_ADMIN_API_BASE_URL=https://projeto-arquice.onrender.com
#
# O front faz pedidos a: ${VITE_ADMIN_API_BASE_URL}/api/...
# Se deixar vazio, a página /adm usa valores de siteConfig.ts (só build local).
# VITE_ADMIN_API_BASE_URL=
